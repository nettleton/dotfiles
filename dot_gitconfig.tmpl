[alias]
  co = checkout
  ci = commit
  st = status
  br = branch
  hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
  type = cat-file -t
  dump = cat-file -p
[branch]
  sort = -committerdate
[column]
  ui = auto
[commit]
  verbose = true
[core]
  editor = nvim
  excludesfile = ~/.gitignore_global
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
[fetch]
  prune = true
  pruneTags = true
  all = true
[help]
  autocorrect = prompt
[init]
  defaultBranch = main
[merge]
  tool = diff
  conflictstyle = zdiff3
[pull]
  rebase = true
[push]
  default = upstream
  autoSetupRemote = true
  followTags = true
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[rerere]
  enabled = true 
  autoupdate = true 
[tag]
  sort = version:refname
{{ if .is_work_machine }}
[url "git@github.{{ .work.domain }}:"]
    insteadOf = https://github.{{ .work.domain }}
{{- end }}
# HTTPS github.com auth via the gh CLI's stored token. Prompt-free in
# unattended contexts (launchd brew update fetching private taps) — unlike
# SSH, which routes through the 1Password agent and pops an authorization
# dialog. gh login is configured by 02-06_configure-git-auth.
# ABSOLUTE path: brew update runs git through its shims with a scrubbed PATH
# that lacks /opt/homebrew/bin, so a bare `gh` is "command not found" there.
[credential "https://github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential

[includeIf "hasconfig:remote.*.url:git@github.com:*/**"]
  path = ~/.ssh/github_com_config/.gitconfig
[includeIf "hasconfig:remote.*.url:https://github.com/**"]
  path = ~/.ssh/github_com_config/.gitconfig
{{ if .is_work_machine }}
[includeIf "hasconfig:remote.*.url:git@github.{{ .work.domain }}:*/**"]
  path = ~/.ssh/github_internal_config/.gitconfig
[includeIf "hasconfig:remote.*.url:https://github.{{ .work.domain }}/**"]
  path = ~/.ssh/github_internal_config/.gitconfig
[includeIf "hasconfig:remote.*.url:git@*-git.{{ .work.domain }}:*/**"]
  path = ~/.ssh/gitlab_internal_config/.gitconfig
[includeIf "hasconfig:remote.*.url:https://*-git.{{ .work.domain }}/**"]
  path = ~/.ssh/gitlab_internal_config/.gitconfig
{{- end }}
{{ if .is_personal_machine }}
[includeIf "hasconfig:remote.*.url:git@gitlab.com:*/**"]
  path = ~/.ssh/gitlab_com_config/.gitconfig
[includeIf "hasconfig:remote.*.url:https://gitlab.com/**"]
  path = ~/.ssh/gitlab_com_config/.gitconfig
{{- end }}

