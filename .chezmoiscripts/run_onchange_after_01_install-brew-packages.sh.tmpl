{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

# Fail fast and loud: a partial run of this script is worse than no run — the
# prune at the end must never execute after a failed tap or install step.
set -euo pipefail

# Save and unset SUDO_ASKPASS so brew doesn't hang on custom askpass programs
existing_sudo_askpass="${SUDO_ASKPASS:-}"
unset SUDO_ASKPASS

{{ if eq .chezmoi.arch "arm64" -}}
find /Library/Apple/usr/lib/ -name "*Rosetta*" || sudo softwareupdate --install-rosetta
{{ end -}}

export HOMEBREW_GITHUB_API_TOKEN="$(op read 'op://Family/nettleton-homebrew-install-token/token')"
# Same token raises the GitHub API limit for safe-install's release-age checks
# (60/hr unauthenticated -> 5000/hr). Without it a fresh-machine bootstrap of
# ~150 packages would rate-limit and fail closed.
export GH_TOKEN="$HOMEBREW_GITHUB_API_TOKEN"
if [ -z "$HOMEBREW_GITHUB_API_TOKEN" ]; then
  echo "error: GitHub token did not resolve from 1Password; aborting before any install/prune" >&2
  exit 1
fi

# Private tap (nettleton/tap) is fetched over HTTPS. Normally the gh credential
# helper in ~/.gitconfig serves credentials, but that chain has two bootstrap
# gaps: gh itself is installed by THIS script, and gh login happens later
# (02-06_configure-git-auth). If the helper can't serve credentials, append an
# inline helper (via git's environment config, scoped to this script) that
# serves the op-sourced token. Verified BEFORE any install or prune runs: an
# unreachable tap must not cascade into a mass install-skip followed by a prune.
tap_url="https://github.com/nettleton/homebrew-tap.git"
if ! GIT_TERMINAL_PROMPT=0 git ls-remote "$tap_url" >/dev/null 2>&1; then
  export GIT_CONFIG_COUNT=1
  export GIT_CONFIG_KEY_0="credential.https://github.com.helper"
  export GIT_CONFIG_VALUE_0='!f() { echo username=x-access-token; echo "password=${GH_TOKEN}"; }; f'
  if ! GIT_TERMINAL_PROMPT=0 git ls-remote "$tap_url" >/dev/null 2>&1; then
    echo "error: cannot authenticate to $tap_url (gh helper and token fallback both failed); aborting" >&2
    exit 1
  fi
fi

# Render the Brewfile to a temp file. It is the single source of truth for the
# declared set: taps install (step 1) and the prune (step 3) both read it.
# (safe-upgrade is installed early by run_before_00_bootstrap.sh, but stays
# declared in packages.yaml — same pattern as 1Password — so the prune, the
# managed trust.json, and the package audits all treat it normally.)
brewfile="$(mktemp -t chezmoi-brewfile.XXXXXX)"
trap 'rm -f "$brewfile"' EXIT
cat >"$brewfile" <<EOF
{{ range .packages.brew.taps -}}
tap "{{ .name }}"{{ with get . "url" }}, "{{ . }}"{{ end }}{{ if get . "trusted" }}, trusted: true{{ end }}
{{ end -}}
{{ range .packages.brew.brews | sortAlpha | uniq -}}
brew "{{ . }}"
{{ end -}}
{{ if .personalpackages -}}
{{ range .packages.brew.personal_brews | sortAlpha | uniq -}}
brew "{{ . }}"
{{ end -}}
{{ end -}}
{{ range .packages.brew.casks | sortAlpha | uniq -}}
cask "{{ . }}"
{{ end -}}
{{ if .personalpackages -}}
{{ range .packages.brew.personal_casks | sortAlpha | uniq -}}
cask "{{ . }}"
{{ end -}}
{{ end -}}
EOF

# 1) Taps only, via brew bundle (idempotent; carries trust: and custom URLs).
grep '^tap ' "$brewfile" | brew bundle --file=/dev/stdin

# 2) Install declared formulae/casks through the security gate (replaces the
#    former `brew bundle` install, which also UPGRADED every outdated declared
#    package ungated). safe-install:
#      - holds packages whose bottle was published < 7 days ago (supply-chain
#        cushion), skipping them with exit 0;
#      - fail-closed CVE check (OSV + NVD + GitHub Advisory) and bottle SHA
#        verification on everything it would install (incl. new dependencies).
#    Only MISSING (declared − installed) packages are handed to safe-install —
#    same missing_of logic as the daily updater's reconcile pass: it avoids a
#    `brew info` process per already-installed package, and safe-install exits
#    1 when given nothing installable ("No clean packages to install").
#
#    The freshness hold exists to slow down UPGRADES of working packages; it
#    must not leave a fresh machine permanently without a declared tool. So
#    after the held pass, anything STILL missing (held as too-new, or a live
#    CVE) is offered for install with the hold disabled (--min-age 0). The CVE
#    and SHA checks still apply, so a genuinely vulnerable package stays blocked
#    even if you say yes. Non-interactive runs (no controlling tty) never
#    prompt and leave the package held — the daily updater installs it once it
#    ages out (the updater is unattended and keeps the hold, by design).
missing_of() { # <declared-names> <installed-names> -> declared-not-installed,
               # as FULL declared tokens (tapped names must keep vendor/tap/).
  local declared="$1" installed="$2" m
  comm -23 <(printf '%s\n' "$declared" | sed 's|.*/||' | sort -u) \
           <(printf '%s\n' "$installed" | sed 's|.*/||' | sort -u) \
    | while IFS= read -r m; do
        [[ -n "$m" ]] && printf '%s\n' "$declared" | grep -E "(^|/)${m}$" | head -1
      done
}
install_missing() { # $1=label  $2=brew-list-kind (formula|cask)  $3=safe-install kind flag  $4=declared tokens
  local label="$1" kind="$2" kindflag="$3" declared="$4" missing held
  missing="$(missing_of "$declared" "$(brew list --"$kind" -1 2>/dev/null || true)")"
  if [[ -z "$missing" ]]; then
    echo "all declared $label installed — nothing to install"
    return 0
  fi
  # First pass: the normal freshness hold. `|| true` because an all-held batch
  # can exit non-zero; the recompute below is the authoritative check.
  # shellcheck disable=SC2086
  brew safe-install $kindflag --min-age 7 $missing || true
  held="$(missing_of "$declared" "$(brew list --"$kind" -1 2>/dev/null || true)")"
  [[ -z "$held" ]] && return 0
  echo "" >&2
  echo "Declared $label still missing after the freshness-hold pass: $held" >&2
  echo "(bottle < 7 days old, or blocked by a CVE)." >&2
  if [[ ! -e /dev/tty ]]; then
    echo "non-interactive run — leaving held; the daily updater installs once aged out." >&2
    return 0
  fi
  local reply=""
  printf 'Install now with the freshness hold disabled? CVE + SHA checks still apply. [y/N] ' >&2
  read -r reply </dev/tty || true
  printf '> %s\n' "${reply:-N}" >&2   # echo the keystroke (a /dev/tty read often isn't echoed)
  case "$reply" in
    [yY]*)
      # shellcheck disable=SC2086
      brew safe-install $kindflag --min-age 0 $held \
        || echo "WARN: could not install $held (likely a live CVE block); continuing." >&2 ;;
    *) echo "Left held; the daily updater will install it once it ages out." >&2 ;;
  esac
}
install_missing formulae formula ""       "$(awk -F'"' '/^brew /{print $2}' "$brewfile")"
install_missing casks    cask    "--cask" "$(awk -F'"' '/^cask /{print $2}' "$brewfile")"

# 3) Prune drift: uninstall any brew/cask not declared in the config, forcing
#    everything to live in chezmoi. Scoped to --brews and --casks ONLY — never
#    taps, mas, go, etc., since those live in separate managers and are absent
#    from this Brewfile (cleaning them here would wipe every Mac App Store app
#    and go binary). The dependency closure of declared packages is preserved
#    automatically. A held (not-yet-installed) declared package is simply
#    absent and is unaffected by cleanup. A no-force plan pass prints exactly
#    what would be removed (so anything worth keeping can be added to
#    packages.yaml); after an interactive confirm, --force performs it. A plan
#    that can't resolve an installed package (formula/cask deleted upstream —
#    e.g. an archived tap) is reported with the exact commands to clear it.
echo "==> Pruning Homebrew packages not declared in chezmoi config:"
# Plan pass: no --force. Per brew's help it exits 1 iff something would be
# removed; capture output+rc (|| plan_rc=$? keeps set -e happy on that 1).
prune_plan="$(brew bundle cleanup --brews --casks --file="$brewfile" 2>&1)" && plan_rc=0 || plan_rc=$?
# Show the plan, minus brew's own "Run ... --force" hint — this script drives
# the force pass itself, so the hint would just be a redundant instruction.
printf '%s\n' "$prune_plan" | grep -vF 'bundle cleanup --force' || true

# Blocked prune: an INSTALLED package no longer resolves (formula/cask gone from
# a now-archived/deprecated tap, e.g. homebrew/brew-vulns). bundle cleanup can't
# uninstall a package whose formula is gone — surface the exact fix and stop.
orphans="$(printf '%s\n' "$prune_plan" \
  | sed -nE 's/^Error: No available (formula|cask) with the name "([^"]+)".*/\2/p' | sort -u)"
if [[ -n "$orphans" ]]; then
  {
    echo ""
    echo "PRUNE BLOCKED — installed package(s) no longer resolve upstream (archived or"
    echo "removed tap/formula). 'brew bundle cleanup' can't remove these; run directly:"
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      printf '  brew uninstall %s\n' "${p##*/}"
      case "$p" in */*/*) printf '  brew untap %s\n' "${p%/*}" ;; esac
    done <<<"$orphans"
    echo "then re-run 'chezmoi apply'."
  } >&2
  exit 1
fi

if [[ "$plan_rc" -eq 0 ]]; then
  echo "no undeclared packages — nothing to prune"
else
  # Removals pending. Confirm interactively, echoing the keystroke (a /dev/tty
  # read often isn't echoed by the terminal), then run --force behind a clear
  # start line so the frequently-long uninstall isn't a silent pause.
  proceed=1
  if [[ -e /dev/tty ]]; then
    reply=""
    printf 'Proceed with uninstalling the above undeclared package(s)? [y/N] ' >&2
    read -r reply </dev/tty || true
    printf '> %s\n' "${reply:-N}" >&2
    [[ "$reply" == [yY]* ]] || proceed=0
  fi
  if [[ "$proceed" -eq 1 ]]; then
    echo "==> Running: brew bundle cleanup --force (uninstalling drift, may take a moment)…"
    brew bundle cleanup --brews --casks --force --file="$brewfile"
  else
    echo "prune skipped; undeclared package(s) left in place." >&2
  fi
fi

# (Tap trust needs no reconcile step here: ~/.homebrew/trust.json is a
#  chezmoi-managed template rendered from the same packages.yaml taps —
#  see private_dot_homebrew/private_trust.json.tmpl — so trust drift is
#  reverted declaratively on every apply.)

export SUDO_ASKPASS="$existing_sudo_askpass"
{{ end -}}
