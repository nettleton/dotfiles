{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.mas.apps -}}
mas "{{ .name }}", id: {{ .id }}
{{ end -}}
{{ if .personalpackages -}}
{{ range .packages.mas.personal_apps -}}
mas "{{ .name }}", id: {{ .id }}
{{ end -}}
{{ end -}}
EOF

{{ end -}}
