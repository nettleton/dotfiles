		dockutil --no-restart --remove "$dockItemLabel"
		DOCK_ITEMS_REMOVED=1
	fi
done

###############################################################################
# Conditionally restart affected applications                                 #
###############################################################################

check_and_prompt_restart() {
  local domain="$1" before="$2" app="$3"
  local after
  after=$(snapshot_domain "$domain")
  if [ "$before" != "$after" ]; then
    if killall -0 "$app" 2>/dev/null; then
      read -p "'$app' preferences changed. Restart to apply? [y/N] " -n 1 -r
      echo
      [[ $REPLY =~ ^[Yy]$ ]] && killall "$app" 2>/dev/null
    else
      echo "$app preferences changed but app is not running"
    fi
  else
    echo "$app preferences unchanged, skipping restart"
  fi
}

# Dock: restart if preferences changed OR dock items were removed
SNAP_DOCK_AFTER=$(snapshot_domain com.apple.dock)
if [ "$SNAP_DOCK" != "$SNAP_DOCK_AFTER" ] || [ "$DOCK_ITEMS_REMOVED" = "1" ]; then
  echo "Dock preferences changed, restarting Dock..."
  killall Dock 2>/dev/null
else
  echo "Dock preferences unchanged, skipping restart"
fi

check_and_prompt_restart com.apple.finder "$SNAP_FINDER" "Finder"
check_and_prompt_restart com.apple.Safari "$SNAP_SAFARI" "Safari"
check_and_prompt_restart com.apple.mail "$SNAP_MAIL" "Mail"
check_and_prompt_restart com.apple.messageshelper.MessageController "$SNAP_MESSAGES" "Messages"
check_and_prompt_restart com.google.Chrome "$SNAP_CHROME" "Google Chrome"
check_and_prompt_restart com.google.Chrome.canary "$SNAP_CHROME_CANARY" "Google Chrome Canary"
check_and_prompt_restart com.apple.terminal "$SNAP_TERMINAL" "Terminal"
check_and_prompt_restart com.apple.ActivityMonitor "$SNAP_ACTMON" "Activity Monitor"
check_and_prompt_restart com.apple.addressbook "$SNAP_ADDRESSBOOK" "Contacts"
check_and_prompt_restart com.apple.iCal "$SNAP_ICAL" "Calendar"

# Restart SystemUIServer if global preferences changed
SNAP_GLOBAL_AFTER=$(snapshot_domain NSGlobalDomain)
if [ "$SNAP_GLOBAL" != "$SNAP_GLOBAL_AFTER" ]; then
  if killall -0 SystemUIServer 2>/dev/null; then
    read -p "Global preferences changed. Restart SystemUIServer? [y/N] " -n 1 -r
    echo
    [[ $REPLY =~ ^[Yy]$ ]] && killall SystemUIServer 2>/dev/null
  else
    echo "Global preferences changed but SystemUIServer is not running"
  fi
else
  echo "Global preferences unchanged, skipping SystemUIServer restart"
fi

echo "Done. Note that some of these changes require a logout/restart to take effect."
