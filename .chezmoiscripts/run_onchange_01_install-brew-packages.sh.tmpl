{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

# Save and unset SUDO_ASKPASS so brew doesn't hang on custom askpass programs
existing_sudo_askpass="$SUDO_ASKPASS"
unset SUDO_ASKPASS

{{ if eq .chezmoi.arch "arm64" -}}
find /Library/Apple/usr/lib/ -name "*Rosetta*" || sudo softwareupdate --install-rosetta
{{ end -}}

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brew.taps | sortAlpha | uniq -}}
tap "{{ . }}"
{{ end -}}
{{ range .packages.brew.brews | sortAlpha | uniq -}}
brew "{{ . }}"
{{ end -}}
{{ if .personalpackages -}}
{{ range .packages.brew.personal_brews | sortAlpha | uniq -}}
brew "{{ . }}"
{{ end -}}
{{ end -}}
{{ range .packages.brew.casks | sortAlpha | uniq -}}
cask "{{ . }}"
{{ end -}}
{{ if .personalpackages -}}
{{ range .packages.brew.personal_casks | sortAlpha | uniq -}}
cask "{{ . }}"
{{ end -}}
{{ end -}}
EOF

# Install calbuddy from private tap separately so a tap failure
# (e.g. SSH keys not yet available) doesn't block other packages.
if brew tap nettleton/tap "git@github.com:nettleton/homebrew-tap.git" 2>/dev/null; then
  brew install nettleton/tap/calbuddy
else
  echo "Warning: could not tap nettleton/tap — skipping calbuddy (re-run chezmoi apply after SSH keys are configured)"
fi

export SUDO_ASKPASS="$existing_sudo_askpass"
{{ end -}}
